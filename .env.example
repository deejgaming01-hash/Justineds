# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_DRIVE_API_KEY: Required for listing files in public Google Drive folders.
# Get one from the Google Cloud Console (APIs & Services > Credentials).
# Ensure the Google Drive API and Google Sheets API are enabled for your project.
GOOGLE_DRIVE_API_KEY="YOUR_GOOGLE_DRIVE_API_KEY"

# GOOGLE_SHEET_ID: The ID of your Google Sheet for activity logs.
# Found in the URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID="YOUR_SPREADSHEET_ID"

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
