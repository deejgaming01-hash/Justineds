{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile picture URL." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Timestamp of the last login." }
      },
      "required": ["uid", "email"]
    },
    "activityLogs": {
      "title": "Activity Log",
      "description": "Stores user activity logs (also synced to Google Sheets).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID who performed the action." },
        "email": { "type": "string", "description": "User's email." },
        "action": { "type": "string", "description": "The action performed (e.g., OPEN_TOPIC, QUIZ_START)." },
        "details": { "type": "string", "description": "Additional details about the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." }
      },
      "required": ["uid", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profile documents."
    },
    "/activityLogs/{logId}": {
      "schema": "activityLogs",
      "description": "Collection of all user activity logs."
    }
  }
}
